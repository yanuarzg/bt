rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Check if user is authenticated and is accessing their own tenant
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }
    
    // Check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // User profile: only the user themselves can read and write
    match /users/{userId} {
      allow read, write: if isOwner(userId);
      
      // Warung catalog: only the warung owner can read/write their own catalog
      match /katalog/{itemId} {
        allow read, write: if isOwner(userId);
      }
      
      // Transactions: only the warung owner can read/write their own transactions
      match /transactions/{transactionId} {
        allow read, write: if isOwner(userId);
      }
    }
    
    // Global crowdsourced catalog: any authenticated user can read or create/update items
    match /katalog_pusat/{productId} {
      allow read, write: if isAuthenticated();
    }
  }
}
